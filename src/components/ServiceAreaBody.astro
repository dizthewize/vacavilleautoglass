---
import LeadCaptureForm from './LeadCaptureForm.astro';
import { SERVICES, CITIES } from '../data/site';

export interface Props {
  cityName: string;
  citySlug: string;
  landmark: string;
  neighbors: string;
}

const { cityName, citySlug, landmark, neighbors } = Astro.props;

const otherCities = CITIES.filter((c) => c.slug !== citySlug);
---
<section class="section-py bg-bg">
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-10 lg:gap-14">
      <div>
        <p class="font-body text-lg text-text leading-loose mb-5">
          We've been serving {cityName} drivers for years — most appointments booked before noon are handled the same day. Our mobile unit covers every neighborhood in {cityName}, plus nearby {neighbors}. {landmark}
        </p>
        <p class="font-body text-lg text-text leading-loose">
          Every job in {cityName} is backed by the same lifetime installation warranty, OEM-quality glass, and insurance direct billing as a shop visit — you just skip the trip.
        </p>

        <h2 class="font-display font-extrabold text-2xl text-text mt-10 mb-4">Services offered in {cityName}</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 list-none p-0">
          {SERVICES.map((svc) => (
            <li>
              <a
                href={`/services/${svc.slug}`}
                class="flex items-center gap-2 p-3 bg-surface border border-border rounded-md hover:border-primary transition-colors text-text font-semibold"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="text-sm">{svc.name}</span>
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-8 bg-surface border border-border rounded-lg p-5">
          <p class="font-body font-semibold text-sm uppercase tracking-wide text-text-muted mb-1">Local Trust</p>
          <p class="font-body text-base text-text">
            Licensed in Solano County · Insurance direct billing · Lifetime warranty
          </p>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="#service-area-lead-form"
            class="btn-primary inline-flex items-center justify-center bg-accent text-text-inverse font-display font-black text-base uppercase tracking-wide rounded-md px-6 py-3"
          >
            Get a Free Quote for {cityName}
          </a>
          <a
            href="tel:+19166122126"
            class="inline-flex items-center justify-center border-2 border-primary text-primary hover:bg-primary hover:text-text-inverse transition-colors font-display font-bold text-base uppercase tracking-wide rounded-md px-6 py-3"
            aria-label="Call Vacaville Auto Glass"
          >
            Call (916) 612-2126
          </a>
        </div>
      </div>

      <div>
        <LeadCaptureForm
          formId="service-area-lead-form"
          formName="service-area-quote"
          title={`Free Quote for ${cityName}`}
          intent={`service-area-${citySlug}`}
        />
      </div>
    </div>
  </div>
</section>

<section class="pb-16 bg-bg">
  <div class="container-site">
    <h2 class="font-display font-bold text-xl text-text mb-4">Other Cities We Serve</h2>
    <ul class="flex flex-wrap gap-2 list-none p-0">
      {otherCities.map((c) => (
        <li>
          <a
            href={`/service-areas/${c.slug}`}
            class="inline-flex px-4 py-2 bg-surface border border-border rounded-full text-sm font-body font-semibold text-primary hover:bg-primary hover:text-text-inverse transition-colors"
          >
            {c.name}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/service-areas"
          class="inline-flex px-4 py-2 bg-surface border border-border rounded-full text-sm font-body font-semibold text-accent hover:bg-accent hover:text-text-inverse transition-colors"
        >
          See all areas →
        </a>
      </li>
    </ul>
  </div>
</section>
