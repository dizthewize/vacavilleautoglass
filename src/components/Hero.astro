---
import LeadCaptureForm from './LeadCaptureForm.astro';

export interface Props {
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  mobileSubheadline?: string;
  showForm?: boolean;
  formTitle?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  ctaTertiary?: { label: string; href: string };
}

const {
  eyebrow,
  headline,
  subheadline,
  mobileSubheadline,
  showForm = false,
  formTitle = 'Get a Free Quote in 60 Seconds',
  ctaPrimary,
  ctaSecondary,
  ctaTertiary,
} = Astro.props;
---
<section class="hero-gradient relative overflow-hidden">
  {/* TODO: replace with AI-generated hero-bg.webp via /site-builder start-at=images */}
  <div class="container-site relative py-16 md:py-24">
    <div class={`grid gap-10 md:gap-16 items-center ${showForm ? 'md:grid-cols-[1.15fr_1fr]' : 'max-w-3xl'}`}>
      <div>
        {eyebrow && (
          <p class="font-body font-bold text-xs uppercase tracking-[0.1em] text-accent mb-4">
            {eyebrow}
          </p>
        )}
        <h1 class="font-display font-black text-white text-5xl md:text-6xl leading-tight tracking-tight mb-5">
          {headline}
        </h1>
        {subheadline && (
          <p class="hidden md:block font-body text-xl text-white/85 leading-normal max-w-xl mb-6">
            {subheadline}
          </p>
        )}
        {mobileSubheadline && (
          <p class="md:hidden font-body text-base text-white/85 leading-normal mb-6">
            {mobileSubheadline}
          </p>
        )}
        <div class="flex flex-wrap gap-3 md:gap-4 items-center">
          {ctaPrimary && (
            <a
              href={ctaPrimary.href}
              class="btn-primary inline-flex items-center justify-center bg-accent text-text-inverse font-display font-black text-base md:text-lg uppercase tracking-wide rounded-md px-6 md:px-8 py-3 md:py-4"
            >
              {ctaPrimary.label}
            </a>
          )}
          {ctaSecondary && (
            <a
              href={ctaSecondary.href}
              class="inline-flex items-center justify-center border-2 border-white/60 text-white hover:bg-white hover:text-primary transition-colors font-display font-bold text-base uppercase tracking-wide rounded-md px-6 py-3"
            >
              {ctaSecondary.label}
            </a>
          )}
          {ctaTertiary && (
            <a
              href={ctaTertiary.href}
              class="inline-flex items-center text-white/85 hover:text-accent font-body font-semibold text-base border-b border-white/40 hover:border-accent transition-colors"
            >
              {ctaTertiary.label}
            </a>
          )}
        </div>

        {showForm && (
          <ul class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-white/85 text-sm font-body font-semibold">
            <li class="flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Licensed &amp; Insured
            </li>
            <li class="flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              All Insurance Accepted
            </li>
            <li class="flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Lifetime Warranty
            </li>
            <li class="flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Same-Day Service
            </li>
          </ul>
        )}
      </div>

      {showForm && (
        <div>
          <LeadCaptureForm title={formTitle} />
        </div>
      )}
    </div>
  </div>
</section>
