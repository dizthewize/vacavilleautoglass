---
import LeadCaptureForm from './LeadCaptureForm.astro';

export interface Props {
  paragraphs: string[];
  benefits: string[];
  ctaLabel: string;
  defaultService?: string;
  intent?: string;
}

const { paragraphs, benefits, ctaLabel, defaultService, intent } = Astro.props;
---
<section class="section-py bg-bg">
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-10 lg:gap-14">
      <div class="prose-like">
        {paragraphs.map((p) => (
          <p class="font-body text-lg text-text leading-loose mb-5">{p}</p>
        ))}

        <h2 class="font-display font-extrabold text-2xl text-text mt-8 mb-4">Benefits</h2>
        <ul class="space-y-3 list-none p-0">
          {benefits.map((b) => (
            <li class="flex items-start gap-3 text-base text-text font-body leading-normal">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0 mt-1" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>{b}</span>
            </li>
          ))}
        </ul>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="#service-lead-form"
            class="btn-primary inline-flex items-center justify-center bg-accent text-text-inverse font-display font-black text-base uppercase tracking-wide rounded-md px-6 py-3"
          >
            {ctaLabel}
          </a>
          <a
            href="tel:+19166122126"
            class="inline-flex items-center justify-center border-2 border-primary text-primary hover:bg-primary hover:text-text-inverse transition-colors font-display font-bold text-base uppercase tracking-wide rounded-md px-6 py-3"
            aria-label="Call Vacaville Auto Glass"
          >
            Call (916) 612-2126
          </a>
        </div>
      </div>

      <div>
        <LeadCaptureForm
          formId="service-lead-form"
          formName="service-quote"
          title="Get a Quote for This Service"
          defaultService={defaultService}
          intent={intent}
        />
      </div>
    </div>
  </div>
</section>
