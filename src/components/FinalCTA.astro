---
import LeadCaptureForm from './LeadCaptureForm.astro';

export interface Props {
  eyebrow?: string;
  headline?: string;
  subheadline?: string;
  formId?: string;
  formTitle?: string;
}

const {
  eyebrow = 'Ready for a Free Quote?',
  headline = 'Book Your Mobile Auto Glass Service',
  subheadline = 'Call (916) 612-2126 or request one online — we\'ll come to you.',
  formId = 'final-lead-form',
  formTitle = 'Request Your Free Quote',
} = Astro.props;
---
<section class="bg-primary text-text-inverse relative overflow-hidden">
  <div class="container-site py-16 md:py-24 relative">
    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-10 lg:gap-16 items-center">
      <div>
        <p class="font-body font-bold text-xs uppercase tracking-[0.1em] text-accent mb-4">{eyebrow}</p>
        <h2 class="font-display font-black text-4xl md:text-5xl leading-tight tracking-tight mb-5">
          {headline}
        </h2>
        <p class="font-body text-lg text-white/85 mb-8 max-w-xl leading-normal">
          {subheadline}
        </p>
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="tel:+19166122126"
            class="inline-flex items-center gap-2 font-display font-extrabold text-2xl md:text-3xl text-text-inverse hover:text-accent transition-colors"
            aria-label="Call Vacaville Auto Glass"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            (916) 612-2126
          </a>
          <a
            href={`#${formId}`}
            class="btn-primary inline-flex items-center justify-center bg-accent text-text-inverse font-display font-black text-base md:text-lg uppercase tracking-wide rounded-md px-6 md:px-8 py-3 md:py-4"
          >
            Get a Free Quote
          </a>
        </div>
      </div>
      <div>
        <LeadCaptureForm formId={formId} formName="final-cta-quote" title={formTitle} />
      </div>
    </div>
  </div>
</section>
