---
import Breadcrumbs from './Breadcrumbs.astro';

export interface Props {
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const { eyebrow, headline, subheadline, breadcrumbs } = Astro.props;
---
<section class="hero-inner bg-primary text-text-inverse">
  <div class="container-site py-14 md:py-20 text-center">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <div class="mb-4 flex justify-center">
        <Breadcrumbs items={breadcrumbs} variant="on-dark" />
      </div>
    )}
    {eyebrow && !breadcrumbs && (
      <p class="font-body font-bold text-xs uppercase tracking-[0.1em] text-accent mb-3">{eyebrow}</p>
    )}
    <h1 class="font-display font-black text-4xl md:text-5xl leading-tight tracking-tight max-w-4xl mx-auto">
      {headline}
    </h1>
    {subheadline && (
      <p class="mt-4 font-body text-lg md:text-xl text-white/85 max-w-2xl mx-auto leading-normal">
        {subheadline}
      </p>
    )}
  </div>
</section>
