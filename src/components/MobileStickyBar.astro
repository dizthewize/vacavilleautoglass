---
// Fixed bottom bar, mobile-only: Call Now | Free Quote
---
<div
  class="mobile-sticky-bar md:hidden fixed bottom-0 left-0 right-0 z-40 flex h-16 bg-primary"
  style="box-shadow: 0 -2px 8px rgba(0,0,0,0.15);"
  role="region"
  aria-label="Quick actions"
>
  <a
    href="tel:+19166122126"
    class="flex-1 flex items-center justify-center gap-2 text-text-inverse font-display font-extrabold text-sm uppercase tracking-wide"
    aria-label="Call Vacaville Auto Glass"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    Call Now
  </a>
  <div class="w-px bg-white/20" aria-hidden="true"></div>
  <a
    href="#lead-form"
    class="flex-1 flex items-center justify-center bg-accent text-text-inverse font-display font-black text-sm uppercase tracking-wide"
  >
    Free Quote
  </a>
</div>
