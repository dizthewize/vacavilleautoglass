---
import Layout from '../layouts/Layout.astro';
import InnerPageHero from '../components/InnerPageHero.astro';

const title = 'Thanks — We\'ll Be in Touch | Vacaville Auto Glass';
const description = 'Thanks for reaching out. We\'ll text or call you back within an hour during business hours.';
---
<Layout title={title} description={description} noindex={true}>
  <InnerPageHero
    headline="Got it — We'll text you back shortly."
    subheadline="During business hours, expect a reply within an hour. For urgent needs, call us now."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Thank You' },
    ]}
  />

  <section class="section-py bg-bg">
    <div class="container-site max-w-2xl text-center">
      <a
        href="tel:+19166122126"
        class="inline-flex items-center gap-2 font-display font-extrabold text-2xl md:text-3xl text-primary hover:text-accent transition-colors"
        aria-label="Call Vacaville Auto Glass"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        (916) 612-2126
      </a>
      <p class="mt-8 text-base text-text-muted">
        <a href="/" class="text-primary font-semibold border-b border-primary hover:text-accent hover:border-accent">← Back to home</a>
      </p>
    </div>
  </section>
</Layout>
