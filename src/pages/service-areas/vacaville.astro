---
import Layout from '../../layouts/Layout.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';
import ServiceAreaBody from '../../components/ServiceAreaBody.astro';
import TrustSignalsBar from '../../components/TrustSignalsBar.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { CITIES } from '../../data/site';
import { breadcrumbSchema, cityLocalBusinessSchema } from '../../data/schema';

const city = CITIES.find((c) => c.slug === 'vacaville')!;

const title = 'Vacaville Auto Glass — Local Windshield Repair & Replacement';
const description = 'Locally owned auto glass shop in Vacaville, CA. Windshield repair, replacement, and ADAS calibration. Mobile service. (916) 612-2126.';

const jsonLd = [
  cityLocalBusinessSchema(city.name, city.slug),
  breadcrumbSchema([
    { label: 'Home', path: '/' },
    { label: 'Service Areas', path: '/service-areas' },
    { label: city.name, path: `/service-areas/${city.slug}` },
  ]),
];
---
<Layout title={title} description={description} jsonLd={jsonLd}>
  <InnerPageHero
    headline={`Auto Glass in ${city.name}, CA — Mobile Service`}
    subheadline="Same-day windshield replacement, chip repair, and ADAS calibration right in your driveway."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Service Areas', href: '/service-areas' },
      { label: city.name },
    ]}
  />

  <TrustSignalsBar />

  <ServiceAreaBody
    cityName={city.name}
    citySlug={city.slug}
    landmark={city.landmark}
    neighbors={city.neighbors}
  />

  <FinalCTA />
</Layout>
